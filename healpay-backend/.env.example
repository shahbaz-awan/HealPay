# ============================================================
# HealPay Backend — Environment Variables
# Copy this file to .env and fill in real values before running
# ============================================================

# ---------------------------
# Application
# ---------------------------
DEBUG=False

# ---------------------------
# Database
# SQLite is the default for development.
# Switch to PostgreSQL for production:
#   DATABASE_URL=postgresql://user:password@localhost:5432/healpay
# ---------------------------
DATABASE_URL=sqlite:///./healpay.db

# ---------------------------
# Security
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
# MUST be changed before any production deployment!
# ---------------------------
SECRET_KEY=change-me-to-a-randomly-generated-64-char-hex-string

# Encryption key for sensitive DB fields (must be exactly 32 characters)
ENCRYPTION_KEY=change-me-to-a-32-char-secret!!

# ---------------------------
# Google OAuth 2.0 (optional — leave as-is to disable SSO)
# Create credentials at https://console.cloud.google.com/
# ---------------------------
GOOGLE_CLIENT_ID=913499109355-sok9j0mln41hbr3p31ngkbtesuci3o6m.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# ---------------------------
# Frontend URL (used in email verification links)
# ---------------------------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ---------------------------
# SMTP / Email
# Leave SMTP_USER and SMTP_PASSWORD empty to use dev mode —
# OTPs will be printed to the console instead of sent by email.
# ---------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=shiduawan@gmail.com
SMTP_PASSWORD=eqrz rptt imfw rant
SMTP_FROM_EMAIL=noreply@healpay.com

# ---------------------------
# OTP Configuration
# ---------------------------
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=6
