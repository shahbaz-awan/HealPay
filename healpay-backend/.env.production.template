# HealPay Backend — Production Environment Variables
# Copy this to .env on the server / set in Render dashboard
# DO NOT commit this file with real values

# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=production
# DEBUG is automatically False when ENVIRONMENT=production

# ── Database (PostgreSQL — provided by Render) ───────────────────────────────
# Render auto-injects this when you link the healpay-db service
DATABASE_URL=postgresql://healpay_admin:YOUR_PASSWORD@HOST:5432/healpay

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS / URLs ───────────────────────────────────────────────────────────────
# Set FRONTEND_URL to your Vercel deployment URL
FRONTEND_URL=https://healpay.vercel.app
BACKEND_URL=https://healpay-backend.onrender.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password   # Use App Password, not Gmail login
SMTP_FROM_EMAIL=noreply@healpay.com

# ── Mock Services ─────────────────────────────────────────────────────────────
MOCK_ADJUDICATION_DELAY_SECONDS=120    # 2 min for demo; set to 10 for fast testing
MOCK_APPROVAL_RATE=0.82                # 82% of claims approved (realistic)

# ── Field-level Encryption ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_KEY=your-32-char-encryption-key!!
